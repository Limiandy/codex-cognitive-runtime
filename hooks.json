{
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'CODEX_PLUGIN_ROOT=\"${CODEX_PLUGIN_ROOT:-$HOME/plugins/codex-cognitive-runtime}\"; \"$CODEX_PLUGIN_ROOT/hooks/codex-cognitive-runtime-hook.sh\" session_start'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'CODEX_PLUGIN_ROOT=\"${CODEX_PLUGIN_ROOT:-$HOME/plugins/codex-cognitive-runtime}\"; \"$CODEX_PLUGIN_ROOT/hooks/codex-cognitive-runtime-hook.sh\" user_message'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'CODEX_PLUGIN_ROOT=\"${CODEX_PLUGIN_ROOT:-$HOME/plugins/codex-cognitive-runtime}\"; \"$CODEX_PLUGIN_ROOT/hooks/codex-cognitive-runtime-hook.sh\" after_tool_call'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'CODEX_PLUGIN_ROOT=\"${CODEX_PLUGIN_ROOT:-$HOME/plugins/codex-cognitive-runtime}\"; \"$CODEX_PLUGIN_ROOT/hooks/codex-cognitive-runtime-hook.sh\" session_end'"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'CODEX_PLUGIN_ROOT=\"${CODEX_PLUGIN_ROOT:-$HOME/plugins/codex-cognitive-runtime}\"; \"$CODEX_PLUGIN_ROOT/hooks/codex-cognitive-runtime-hook.sh\" precompact'"
          }
        ]
      }
    ]
  }
}
