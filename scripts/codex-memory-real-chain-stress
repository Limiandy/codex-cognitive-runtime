SCENARIO_SETS = {
    "base": BASE_SCENARIOS,
    "expanded": EXPANDED_SCENARIOS,
    "focus": FOCUS_SCENARIOS,
    "world": WORLD_SCENARIOS,
}


def main() -> int:
    parser = argparse.ArgumentParser(description="Run broad real Codex Memory hook chain stress test.")
    parser.add_argument("--rounds", type=int, default=500)
    parser.add_argument("--scenario-set", choices=sorted(SCENARIO_SETS), default="world")
    parser.add_argument("--scenario-file", action="append", help="Optional JSONL file with kind/text/assistant_mode/cwd fields. Repeat or comma-separate to merge files.")
    parser.add_argument("--sample-mode", choices=("sequential", "random"), default="sequential")
    parser.add_argument("--random-seed", type=int, default=20260529)
    parser.add_argument("--start-offset", type=int, default=0, help="Skip already-covered scenario positions before starting this run.")
    parser.add_argument("--coverage-file", default=str(DEFAULT_COVERAGE_PATH), help="JSONL coverage ledger used to skip scenarios already marked passed.")
    parser.add_argument("--rerun-passed", action="store_true", help="Run scenarios even if they are already marked passed in the coverage ledger.")
    parser.add_argument("--govern-every", type=int, default=25)
    parser.add_argument("--wait-timeout", type=int, default=180)
    parser.add_argument("--hook-timeout", type=int, default=90)
    parser.add_argument("--state-dir", default="/private/tmp/codex-memory-real-chain-state")
    parser.add_argument("--log-dir", default="/private/tmp/codex-memory-real-chain-logs")
    parser.add_argument("--clear-before", action="store_true")
    args = parser.parse_args()

    state_dir = Path(args.state_dir)
    log_dir = Path(args.log_dir)
    if args.clear_before:
        for path in (state_dir, log_dir):
            if path.exists():
                shutil.rmtree(path)
    state_dir.mkdir(parents=True, exist_ok=True)
    log_dir.mkdir(parents=True, exist_ok=True)

    start = time.time()
    rounds = []
    snapshots = []
    scenarios = load_scenarios(args)
    args.scenario_count = len(scenarios)
    args.scenario_mode_counts = dict(Counter(mode for _, _, mode, _ in scenarios))
    coverage_path = Path(args.coverage_file) if args.coverage_file else None
    coverage = load_coverage(coverage_path)
    scenario_indices = scenario_order(args, scenarios, coverage, skip_passed=not args.rerun_passed)
    skipped_passed = len(scenarios) - len(scenario_indices) if not args.rerun_passed else 0
    if not scenario_indices:
        report = write_report(state_dir, log_dir, start, args, rounds, snapshots, partial=False, coverage_path=coverage_path, skipped_passed=skipped_passed)
        print(f"REPORT {REPORT_PATH}")
        print(json.dumps(summary(report), ensure_ascii=False, indent=2))
        return 0
    for index in range(args.rounds):
        scenario_index = scenario_indices[index % len(scenario_indices)]
        kind, text, assistant_mode, cwd = scenarios[scenario_index]
        turn_number = args.start_offset + index + 1
        session_id = "real-chain-stress"
        turn_id = f"real-chain-turn-{turn_number:04d}"
        prompt = f"[real-{turn_number:04d}/{kind}] {text}"
        before = event_ids(state_dir)
        user_result = call_hook("user_message", payload(session_id, turn_id, prompt, cwd, state_dir), state_dir, log_dir, args.hook_timeout)
        event_id = newest_event_id(state_dir, before)
        processed = wait_event_processed(state_dir, event_id, args.wait_timeout) if event_id else False
        assistant_message = assistant_response(assistant_mode, user_result)
        stop_result = call_hook(
            "session_end",
            {
                **payload(session_id, turn_id, "", cwd, state_dir),
                "hook_event_name": "Stop",
                "stop_hook_active": False,
                "last_assistant_message": assistant_message,
            },
            state_dir,
            log_dir,
            args.hook_timeout,
        )
        governed = None
        if turn_number % args.govern_every == 0:
            before_metrics = metrics(state_dir)
            governed = govern(state_dir, log_dir)
            after_metrics = metrics(state_dir)
            snapshots.append({"round": turn_number, "before": before_metrics, "governed": governed, "after": after_metrics})
        item = {
            "round": turn_number,
            "scenario_index": scenario_index,
            "scenario_id": scenario_id(kind, text, assistant_mode, cwd),
            "kind": kind,
            "assistant_mode": assistant_mode,
            "processed": processed,
            "event_id": event_id,
            "user_hook_output": compact_hook_output(user_result),
            "session_end_output": compact_hook_output(stop_result),
            "governed": governed is not None,
            "metrics": compact_metrics(state_dir),
        }
        item["coverage_status"] = scenario_run_status(item)
        rounds.append(item)
        record_coverage(
            coverage_path,
            scenario_id=item["scenario_id"],
            kind=kind,
            assistant_mode=assistant_mode,
            cwd=cwd,
            random_seed=args.random_seed if args.sample_mode == "random" else None,
            start_offset=args.start_offset,
            status=item["coverage_status"],
            false_active_count=int(item["metrics"].get("false_active") or 0),
        )
        write_report(state_dir, log_dir, start, args, rounds, snapshots, partial=True, coverage_path=coverage_path, skipped_passed=skipped_passed)
        print(
            f"{turn_number:03d}/{args.rounds} {kind} processed={processed} injected={bool(user_result.get('hookSpecificOutput'))} active={item['metrics'].get('active')}",
            flush=True,
        )

    report = write_report(state_dir, log_dir, start, args, rounds, snapshots, partial=False, coverage_path=coverage_path, skipped_passed=skipped_passed)
    print(f"REPORT {REPORT_PATH}")
    print(json.dumps(summary(report), ensure_ascii=False, indent=2))
    return 0 if report["passed"] else 1


def payload(session_id: str, turn_id: str, prompt: str, cwd: str, state_dir: Path) -> dict[str, Any]:
    return {
        "session_id": session_id,
        "turn_id": turn_id,
        "transcript_path": str(state_dir / "real-chain-transcript.jsonl"),
        "cwd": cwd,
        "hook_event_name": "UserPromptSubmit",
        "model": "gpt-5.5",
        "permission_mode": "bypassPermissions",
        "prompt": prompt,
    }


def call_hook(hook: str, data: dict[str, Any], state_dir: Path, log_dir: Path, timeout: int) -> dict[str, Any]:
    env = os.environ.copy()
    env.pop("CODEX_MEMORY_FAKE_MODEL", None)
    env["PLUGIN_ROOT"] = str(PLUGIN_ROOT)
    env["CODEX_MEMORY_STATE_DIR"] = str(state_dir)
    env["CODEX_MEMORY_LOG_DIR"] = str(log_dir)
    env["CODEX_MEMORY_LOG_LEVEL"] = "DEBUG"
    try:
        proc = subprocess.run(
            [str(HOOK), hook],
            input=json.dumps(data, ensure_ascii=False),
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            env=env,
            timeout=timeout,
        )
    except subprocess.TimeoutExpired as exc:
        return {
            "error": "hook_timeout",
            "hook": hook,
            "timeout_seconds": timeout,
            "stdout": (exc.stdout or "")[-2000:] if isinstance(exc.stdout, str) else "",
            "stderr": (exc.stderr or "")[-2000:] if isinstance(exc.stderr, str) else "",
        }
    if proc.returncode != 0:
        return {"error": proc.stderr.strip() or proc.stdout.strip(), "returncode": proc.returncode}
    try:
        return json.loads(proc.stdout or "{}")
    except json.JSONDecodeError:
        return {"raw": proc.stdout}


def govern(state_dir: Path, log_dir: Path) -> dict[str, Any]:
    env = os.environ.copy()
    env["CODEX_MEMORY_STATE_DIR"] = str(state_dir)
    env["CODEX_MEMORY_LOG_DIR"] = str(log_dir)
    proc = subprocess.run([str(CLI), "govern", "--apply"], text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, env=env, timeout=60)
    if proc.returncode != 0:
        return {"error": proc.stderr.strip() or proc.stdout.strip(), "returncode": proc.returncode}
    try:
        return json.loads(proc.stdout or "{}")
    except json.JSONDecodeError:
        return {"raw": proc.stdout}


def assistant_response(mode: str, hook_result: dict[str, Any]) -> str:
    context = hook_result.get("hookSpecificOutput", {}).get("additionalContext", "")
    if mode == "use" and context:
        return f"我会采用这些记忆继续处理：{context[:1200]}"
    if mode == "negative":
        return "我不会采用刚才那条记忆，因为它误导了回答。"
    if mode == "positive" and context:
        return f"刚才这条记忆有用，我会沿用：{context[:800]}"
    if mode == "ignore":
        return "这次只基于当前输入回答，不采用历史记忆。"
    return "收到。"


def db_path(state_dir: Path) -> Path:
    return state_dir / "ledger.sqlite3"


def connect(state_dir: Path):
    return sqlite3.connect(str(db_path(state_dir)), timeout=60)


def event_ids(state_dir: Path) -> set[str]:
    if not db_path(state_dir).exists():
        return set()
    with connect(state_dir) as conn:
        try:
            return {row[0] for row in conn.execute("SELECT id FROM events")}
        except sqlite3.OperationalError:
            return set()


def newest_event_id(state_dir: Path, before: set[str]) -> str | None:
    if not db_path(state_dir).exists():
        return None
    with connect(state_dir) as conn:
        rows = conn.execute("SELECT id FROM events WHERE event_type='user_message' ORDER BY created_at DESC LIMIT 20").fetchall()
    for (event_id,) in rows:
        if event_id not in before:
            return event_id
    return rows[0][0] if rows else None


def wait_event_processed(state_dir: Path, event_id: str, timeout: int) -> bool:
    deadline = time.time() + timeout
    while time.time() < deadline:
        with connect(state_dir) as conn:
            row = conn.execute("SELECT processed_at, process_error FROM events WHERE id=?", (event_id,)).fetchone()
        if row and row[0]:
            return True
        if row and row[1]:
            return False
        time.sleep(1)
    return False


def metrics(state_dir: Path) -> dict[str, Any]:
    if not db_path(state_dir).exists():
        return {"status": {}, "events": {"pending": 0, "failed": 0}}
    with connect(state_dir) as conn:
        conn.row_factory = sqlite3.Row
        status = {row["status"]: row["count"] for row in conn.execute("SELECT status, COUNT(*) count FROM memories GROUP BY status")}
        events = {
            "pending": conn.execute("SELECT COUNT(*) count FROM events WHERE processed_at IS NULL AND process_error IS NULL").fetchone()["count"],
            "failed": conn.execute("SELECT COUNT(*) count FROM events WHERE processed_at IS NULL AND process_error IS NOT NULL").fetchone()["count"],
        }
        policies = [_policy(row) for row in conn.execute("SELECT * FROM governance_policies WHERE active=1 ORDER BY created_at")]
        recalls = [_recall(row) for row in conn.execute("SELECT * FROM recall_events ORDER BY created_at")]
        active = [_memory(row) for row in conn.execute("SELECT * FROM memories WHERE status='active' ORDER BY created_at")]
    false_active = [item for item in active if false_active_reasons(item)]
    recall_sizes = [len(row.get("memory_ids_json") or []) for row in recalls]
    return {
        "status": status,
        "events": events,
        "active_count": status.get("active", 0),
        "false_active_count": len(false_active),
        "false_active": [{"id": item["id"], "content": item["content"], "reasons": false_active_reasons(item)} for item in false_active[:20]],
        "policy_count": len(policies),
        "policy_hits": sum(int(policy.get("hit_count") or 0) for policy in policies),
        "policies": policies,
        "recall_event_count": len(recalls),
        "total_injected": sum(recall_sizes),
        "avg_injected": round(mean(recall_sizes), 3) if recall_sizes else 0,
        "policy_effects": policy_effects(policies, recalls),
    }


def compact_metrics(state_dir: Path) -> dict[str, Any]:
    data = metrics(state_dir)
    return {
        "active": data["active_count"],
        "false_active": data["false_active_count"],
        "policies": data["policy_count"],
        "policy_hits": data["policy_hits"],
        "pending": data["events"]["pending"],
        "failed": data["events"]["failed"],
    }


def policy_effects(policies: list[dict[str, Any]], recalls: list[dict[str, Any]]) -> list[dict[str, Any]]:
    effects = []
    for policy in policies:
        source_id = str(policy.get("source_memory_id") or "")
        created_at = str(policy.get("created_at") or "")
        before = 0
        after = 0
        for recall in recalls:
            ids = [str(item) for item in recall.get("memory_ids_json") or []]
            if not source_id or source_id not in ids:
                continue
            if str(recall.get("created_at") or "") <= created_at:
                before += 1
            else:
                after += 1
        effects.append(
            {
                "policy_id": policy["id"],
                "policy_type": policy["policy_type"],
                "action": policy["action"],
                "source_memory_id": source_id,
                "hit_count": policy.get("hit_count"),
                "source_recalled_before_policy": before,
                "source_recalled_after_policy": after,
            }
        )
    return effects


def false_active_reasons(memory: dict[str, Any]) -> list[str]:
    content = str(memory.get("content") or "").lower()
    reasons = []
    safe_secret_boundary = any(term in content for term in ("不能包含", "不要包含", "不得包含", "不保存", "不能保存", "不能进入", "不要存", "禁止"))
    if not safe_secret_boundary and ("sk-" in content or "api_key" in content or "ghp_" in content or "token" in content):
        reasons.append("secret_like")
    if memory.get("memory_type") in {"temporary", "task_state"}:
        reasons.append("temporary_or_task_state")
    if "这是一条普通测试消息" in content:
        reasons.append("noise")
    if any(term in content for term in ("每次注入完整流程提醒", "所有项目都应每次", "所有项目都应该每次", "所有测试建议", "所有回答都必须先输出完整检查清单")):
        reasons.append("overbroad_injection_preference")
    if any(term in content for term in ("极长", "特别长", "越长越好", "铺垫很多", "大量铺垫", "长篇铺垫", "very long", "verbose")):
        if any(term in content for term in ("回答", "回复", "写作", "文章", "response", "answer", "writing")):
            reasons.append("low_quality_verbose_preference")
    if (
        any(term in content for term in ("采购", "供应商", "供货商", "supplier", "vendor", "sourcing", "procurement"))
        and any(term in content for term in ("默认", "以后", "总是", "全部", "都", "always", "default"))
        and any(term in content for term in ("最便宜", "最低价", "最低成本", "cheapest", "lowest price", "lowest-cost"))
        and any(term in content for term in ("单一供应商", "单一供货商", "单一来源", "single vendor", "single supplier", "single-source"))
    ):
        reasons.append("supply_chain_single_vendor_risk")
    if "mcp" in content and "hook" in content and any(term in content for term in ("互相调用", "互调", "统一链路", "合并链路")):
        if not any(term in content for term in ("不能互相调用", "不得互相调用", "不允许互相调用", "不重叠")):
            reasons.append("mcp_hook_mutual_call")
    if any(term in content for term in (
        "不用确认",
        "不需要确认",
        "无需确认",
        "不用让我确认",
        "直接发送",
        "直接发邮件",
        "直接下单",
        "直接购买",
        "直接付款",
        "直接支付",
        "直接转账",
        "直接删除",
        "直接覆盖",
        "直接改日程",
    )):
        if any(term in content for term in ("发送", "邮件", "下单", "购买", "付款", "支付", "删除", "覆盖", "日程")):
            reasons.append("external_action_without_confirmation")
    if any(term in content for term in ("数学", "证明", "证据", "来源", "研究", "法律", "医疗", "金融", "测试", "验证")):
        if any(term in content for term in ("不用证明", "不要证明", "不用证据", "不要证据", "不用来源", "跳过测试", "跳过验证", "直接给结论")):
            reasons.append("unsafe_skip_reasoning_or_evidence")
    return reasons


def write_report(
    state_dir: Path,
    log_dir: Path,
    start: float,
    args: argparse.Namespace,
    rounds: list[dict[str, Any]],
    snapshots: list[dict[str, Any]],
    partial: bool,
    coverage_path: Path | None = None,
    skipped_passed: int = 0,
) -> dict[str, Any]:
    data = metrics(state_dir)
    policy_repair_proven = (
        data["policy_count"] >= 1
        and data["policy_hits"] >= 1
        and any(effect["source_recalled_before_policy"] > 0 and effect["source_recalled_after_policy"] == 0 for effect in data["policy_effects"])
    )
    hook_error_count = sum(
        1
        for item in rounds
        if item.get("user_hook_output", {}).get("error") or item.get("session_end_output", {}).get("error")
    )
    passed = (
        not partial
        and data["events"]["pending"] == 0
        and data["events"]["failed"] == 0
        and data["false_active_count"] == 0
        and hook_error_count == 0
        and (data["policy_count"] == 0 or policy_repair_proven)
    )
    report = {
        "passed": passed,
        "partial": partial,
        "started_at": iso_now(start),
        "updated_at": iso_now(time.time()),
        "duration_seconds": round(time.time() - start, 2),
        "rounds_requested": args.rounds,
        "rounds_completed": len(rounds),
        "scenario_set": args.scenario_set,
        "scenario_file": args.scenario_file,
        "scenario_count": getattr(args, "scenario_count", len(SCENARIO_SETS[args.scenario_set])),
        "scenario_mode_counts": getattr(args, "scenario_mode_counts", {}),
        "sample_mode": args.sample_mode,
        "random_seed": args.random_seed if args.sample_mode == "random" else None,
        "start_offset": args.start_offset,
        "scenario_order": [item["scenario_index"] for item in rounds],
        "scenario_ids": [item.get("scenario_id") for item in rounds],
        "coverage_file": str(coverage_path) if coverage_path else None,
        "coverage": {
            "skipped_passed": skipped_passed,
            "unique_scenarios_run": len({item.get("scenario_id") for item in rounds}),
            "passed_scenarios_in_run": sum(1 for item in rounds if item.get("coverage_status") == "passed"),
            "failed_scenarios_in_run": sum(1 for item in rounds if item.get("coverage_status") != "passed"),
            "run_mode_counts": dict(Counter(item.get("assistant_mode") for item in rounds)),
        },
        "govern_every": args.govern_every,
        "state_dir": str(state_dir),
        "log_dir": str(log_dir),
        "metrics": data,
        "policy_repair_proven": policy_repair_proven,
        "hook_error_count": hook_error_count,
        "snapshots": snapshots,
        "round_samples": rounds[:10] + rounds[-10:],
    }
    REPORT_PATH.write_text(json.dumps(report, ensure_ascii=False, indent=2), encoding="utf-8")
    return report


def load_scenarios(args: argparse.Namespace) -> list[tuple[str, str, str, str]]:
    if not args.scenario_file:
        return SCENARIO_SETS[args.scenario_set]
    scenarios: list[tuple[str, str, str, str]] = []
    for raw_path in args.scenario_file:
        for item_path in str(raw_path).split(","):
            path = Path(item_path.strip())
            if not str(path):
                continue
            for line_number, line in enumerate(path.read_text(encoding="utf-8").splitlines(), start=1):
                if not line.strip() or line.lstrip().startswith("#"):
                    continue
                try:
                    item = json.loads(line)
                except json.JSONDecodeError as exc:
                    raise SystemExit(f"Invalid scenario JSON at {path}:{line_number}: {exc}") from exc
                try:
                    scenarios.append(
                        (
                            str(item["kind"]),
                            str(item["text"]),
                            str(item.get("assistant_mode") or item.get("mode") or "neutral"),
                            str(item.get("cwd") or "/tmp/world/misc"),
                        )
                    )
                except KeyError as exc:
                    raise SystemExit(f"Missing scenario field {exc} at {path}:{line_number}") from exc
    if not scenarios:
        raise SystemExit("No scenarios found in scenario files")
    return scenarios


def scenario_order(args: argparse.Namespace, scenarios: list[tuple[str, str, str, str]], coverage: dict[str, dict[str, Any]], skip_passed: bool) -> list[int]:
    indices = list(range(len(scenarios)))
    if args.sample_mode == "random":
        rng = random.Random(args.random_seed)
        rng.shuffle(indices)
    offset = args.start_offset % len(scenarios) if scenarios else 0
    ordered = indices[offset:] + indices[:offset]
    if not skip_passed:
        return ordered
    return [
        index for index in ordered
        if coverage.get(scenario_id(*scenarios[index]), {}).get("status") != "passed"
    ]


def scenario_id(kind: str, text: str, assistant_mode: str, cwd: str) -> str:
    digest = hashlib.sha256(f"{kind}\n{text}\n{assistant_mode}\n{cwd}".encode("utf-8")).hexdigest()[:20]
    return f"scenario_{digest}"


def load_coverage(path: Path | None) -> dict[str, dict[str, Any]]:
    if not path or not path.exists():
        return {}
    coverage: dict[str, dict[str, Any]] = {}
    for line in path.read_text(encoding="utf-8").splitlines():
        if not line.strip():
            continue
        try:
            item = json.loads(line)
        except json.JSONDecodeError:
            continue
        sid = str(item.get("scenario_id") or "")
        if sid:
            coverage[sid] = item
    return coverage


def record_coverage(
    path: Path | None,
    *,
    scenario_id: str,
    kind: str,
    assistant_mode: str,
    cwd: str,
    random_seed: int | None,
    start_offset: int,
    status: str,
    false_active_count: int,
) -> None:
    if not path:
        return
    path.parent.mkdir(parents=True, exist_ok=True)
    item = {
        "scenario_id": scenario_id,
        "kind": kind,
        "assistant_mode": assistant_mode,
        "cwd": cwd,
        "status": status,
        "false_active_count": false_active_count,
        "random_seed": random_seed,
        "start_offset": start_offset,
        "validated_at": iso_now(time.time()),
    }
    with path.open("a", encoding="utf-8") as handle:
        handle.write(json.dumps(item, ensure_ascii=False, sort_keys=True) + "\n")


def scenario_run_status(item: dict[str, Any]) -> str:
    if not item.get("processed"):
        return "failed_unprocessed"
    if item.get("user_hook_output", {}).get("error") or item.get("session_end_output", {}).get("error"):
        return "failed_hook"
    metrics_data = item.get("metrics") or {}
    if metrics_data.get("false_active", 0):
        return "failed_false_active"
    if metrics_data.get("pending", 0) or metrics_data.get("failed", 0):
        return "failed_event"
    return "passed"


def summary(report: dict[str, Any]) -> dict[str, Any]:
    metrics_data = report["metrics"]
    return {
        "passed": report["passed"],
        "rounds_completed": report["rounds_completed"],
        "duration_seconds": report["duration_seconds"],
        "status": metrics_data["status"],
        "events": metrics_data["events"],
        "active_count": metrics_data["active_count"],
        "false_active_count": metrics_data["false_active_count"],
        "policy_count": metrics_data["policy_count"],
        "policy_hits": metrics_data["policy_hits"],
        "hook_error_count": report.get("hook_error_count", 0),
        "coverage": report.get("coverage"),
        "recall_event_count": metrics_data["recall_event_count"],
        "avg_injected": metrics_data["avg_injected"],
        "policy_effects": metrics_data["policy_effects"],
    }


def compact_hook_output(data: dict[str, Any]) -> dict[str, Any]:
    if "error" in data:
        return {"error": data["error"][:500], "returncode": data.get("returncode")}
    context = data.get("hookSpecificOutput", {}).get("additionalContext")
    return {"injected": bool(context), "context_chars": len(context or "")}


def _memory(row: sqlite3.Row) -> dict[str, Any]:
    data = dict(row)
    for key in ("evidence_json", "review_json", "review_feedback_json", "triggers_json"):
        try:
            data[key] = json.loads(data[key])
        except (TypeError, json.JSONDecodeError):
            data[key] = None
    return data


def _policy(row: sqlite3.Row) -> dict[str, Any]:
    data = dict(row)
    try:
        data["matcher_json"] = json.loads(data["matcher_json"])
    except (TypeError, json.JSONDecodeError):
        data["matcher_json"] = {}
    return data


def _recall(row: sqlite3.Row) -> dict[str, Any]:
    data = dict(row)
    for key in ("route_json", "memory_ids_json", "outcome_json"):
        try:
            data[key] = json.loads(data[key])
        except (TypeError, json.JSONDecodeError):
            data[key] = [] if key == "memory_ids_json" else {}
    return data


def iso_now(value: float) -> str:
    return datetime.fromtimestamp(value, timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


if __name__ == "__main__":
    raise SystemExit(main())
